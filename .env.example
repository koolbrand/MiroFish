# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Graphiti graph-extraction LLM (optional) =====
# The simulation LLM (LLM_MODEL_NAME) can be a reasoning model (MiniMax-M2.7,
# DeepSeek-R1), but graph extraction needs reliable structured output
# (response_format=json_schema). Reasoning models silently ignore
# json_schema and drift to invented field names → ~50 % invalid extractions.
#
# These three vars configure a SEPARATE provider for Graphiti. Each one
# falls back to its LLM_* counterpart when unset, so you only set the ones
# that differ from the main LLM.
#
# Recommended (tested in production):
#   · BytePlus Seed-2-0-lite    (cheap, supports json_schema)
#   · DeepSeek-V3 (deepseek-chat) — supports json_schema, cheap
#   · Qwen-Plus / Qwen-Max (Aliyun Bailian)
#
# GRAPHITI_LLM_API_KEY=your_byteplus_or_deepseek_key
# GRAPHITI_LLM_BASE_URL=https://ap-southeast.bytepluses.com/api/v3
# GRAPHITI_LLM_MODEL_NAME=seed-2-0-lite-260228

# ===== Vision LLM — image upload support (optional) =====
# When a PNG/JPG/WEBP image is uploaded as the seed document, Mirror calls
# this model to generate a detailed text description before feeding it to
# the simulation pipeline. Uses the same API key and base URL as LLM_*.
#
# MiniMax users: MiniMax-VL-01 supports images; MiniMax-M2.7 does NOT.
# The vision call uses MiniMax's special format (data URI embedded in content).
#
# VISION_LLM_MODEL_NAME=MiniMax-VL-01

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here