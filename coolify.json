{
  "name": "MiroFish",
  "description": "AI Prediction Engine with Multi-Agent Swarm Intelligence",
  "version": "0.1.0",
  "logo": "./static/image/MiroFish_logo_compressed.jpeg",
  "repository": "https://github.com/koolbrand/MiroFish",
  "documentation": "https://github.com/koolbrand/MiroFish/blob/main/README.md",
  "deployment": {
    "type": "docker-compose",
    "dockerfile": "Dockerfile",
    "docker_compose_file": "docker-compose.yml",
    "ports": [
      {
        "port": 8000,
        "protocol": "http",
        "name": "API Server"
      }
    ],
    "env_variables": [
      {
        "key": "LLM_API_KEY",
        "description": "API Key for LLM provider (MiniMax / OpenAI compatible)",
        "required": true,
        "example": "eyJ..."
      },
      {
        "key": "LLM_BASE_URL",
        "description": "Base URL for LLM API",
        "required": true,
        "default": "https://api.minimaxi.chat/v1"
      },
      {
        "key": "LLM_MODEL_NAME",
        "description": "Chat model name",
        "required": true,
        "default": "MiniMax-M2.7"
      },
      {
        "key": "EMBEDDING_MODEL",
        "description": "Embedding model name (must be supported by LLM_BASE_URL provider)",
        "required": false,
        "default": "text-embedding-3-small"
      },
      {
        "key": "NEO4J_URI",
        "description": "Neo4j Bolt URI (auto-set by docker-compose)",
        "required": false,
        "default": "bolt://neo4j:7687"
      },
      {
        "key": "NEO4J_USER",
        "description": "Neo4j username",
        "required": false,
        "default": "neo4j"
      },
      {
        "key": "NEO4J_PASSWORD",
        "description": "Neo4j password — set a strong value",
        "required": true,
        "example": "mirofish2026"
      },
      {
        "key": "DEBUG",
        "description": "Enable debug mode",
        "required": false,
        "default": "false"
      }
    ],
    "volumes": [
      {
        "path": "/app/backend/uploads",
        "description": "User uploads directory"
      },
      {
        "path": "/app/backend/logs",
        "description": "Application logs"
      }
    ],
    "health_check": {
      "endpoint": "/health",
      "interval": 30,
      "timeout": 10,
      "retries": 3
    }
  },
  "requirements": {
    "cpu": "2 cores (recommended 4)",
    "ram": "4GB (Neo4j needs at least 1GB)",
    "disk": "20GB"
  }
}
